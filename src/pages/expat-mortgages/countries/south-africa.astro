---
import HubLayout from '../../../layouts/HubLayout.astro';
import PullQuote from '../../../components/PullQuote.astro';
import MidPageCta from '../../../components/MidPageCta.astro';
import { breadcrumbSchema, articleSchema } from '../../../lib/schema';
import RiskWarning from '../../../components/RiskWarning.astro';

const title = 'UK Mortgages for British Expats in South Africa';
const description =
  'A clear guide to UK mortgages when you live and work in South Africa. What you can borrow, how lenders treat South African rand income, what deposit you need.';
const h1 = 'UK Mortgages for British Expats in South Africa';
const subheadline =
  'A clear guide to UK mortgages when you live and work in South Africa. What you can borrow, how lenders treat South African rand income, what deposit you will need, and how a specialist broker finds the right lender for your situation.';

const relatedPages = [
  {
    eyebrow: 'Hub',
    title: 'UK Mortgages for Expats',
    description:
      'British nationals living abroad. Country-by-country lender appetite, currency haircuts, and timelines.',
    href: '/expat-mortgages',
  },
  {
    eyebrow: 'Hub',
    title: 'UK Mortgages for Non-UK Residents',
    description:
      'Foreign nationals or British expats wanting a UK mortgage on UK property. The lender pool, deposits, and rates explained.',
    href: '/non-uk-resident-mortgages',
  },
  {
    eyebrow: 'Hub',
    title: 'UK Mortgages with Foreign Income',
    description:
      'How lenders treat non-sterling income. The 20% standard haircut and direct access to no-haircut lenders.',
    href: '/uk-mortgage-foreign-income',
  },
  {
    eyebrow: 'Hub',
    title: 'Expat Buy-to-Let Mortgages',
    description:
      'Building a UK rental portfolio from abroad. ICR, lender appetite, and limited company structures.',
    href: '/expat-mortgages/buy-to-let',
  },
];

const faqs = [
  {
    q: "Can I borrow as much from South Africa as I could in the UK?",
    a: "Often less, because of the haircut and ZAR volatility. With a no-haircut lender, sometimes more.",
  },
  {
    q: "Do I need UK income to apply?",
    a: "No. South African income alone is accepted.",
  },
  {
    q: "Will my bonus count?",
    a: "Often, but treatment varies between lenders.",
  },
  {
    q: "How big a deposit do I need?",
    a: "25 percent is the working assumption for residential, 25 to 30 percent for buy-to-let.",
  },
  {
    q: "Does my South African status matter?",
    a: "Most lenders accept SA citizens and permanent residents. Work visa holders may face more scrutiny.",
  },
  {
    q: "Can I use a South African bank statement?",
    a: "Yes. Accepted directly.",
  },
  {
    q: "Is currency volatility an issue?",
    a: "It can be. Some lenders apply heavier haircuts on ZAR. The right lender prices the haircut sensibly.",
  },
  {
    q: "What about Reserve Bank limits on transferring funds?",
    a: "Reserve Bank approvals are routine and well understood by UK lenders. Documentation needs to be clear.",
  },
  {
    q: "Can I remortgage from South Africa?",
    a: "Yes. Common as a fix end approaches.",
  },
  {
    q: "How long does it take?",
    a: "Six to twelve weeks from application to offer. Slightly longer than for most expat markets.",
  },
  {
    q: "Do I need to come back to the UK to sign?",
    a: "No. South African Commissioner of Oaths or notary documents are accepted, as is notarisation through the British High Commission.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'UK Mortgages for Expats', path: '/expat-mortgages' },
    { name: 'South Africa' },
  ]),
  articleSchema({ headline: h1, description }),
];
---

<HubLayout
  title={title}
  description={description}
  h1={h1}
  subheadline={subheadline}
  eyebrow="Hub · South Africa expat mortgages"
  schemas={schemas}
  relatedPages={relatedPages}
>
  <RiskWarning type="residential" />
  <section class="hub-section">
    <div class="hub-section-inner">
      <h2 id="who-this-is-for">Who this page is for</h2>
      <p>
        If you are a British national living in South Africa and you want a
        mortgage on UK property, this page is for you.
      </p>
      <p>
        That includes buying a UK home while you are still based in
        Johannesburg, Cape Town, Durban, or elsewhere, building a <a href="/expat-mortgages/buy-to-let">UK
        buy-to-let portfolio</a> remotely, remortgaging an existing UK property
        as your fix ends, and planning a return to the UK in the next year
        or two.
      </p>
      <p>
        The British expat community in South Africa includes long-term
        residents, dual citizens, and professionals on work assignments.
        Many are also planning a return to the UK and remortgaging or
        buying ahead of that move.
      </p>
    </div>
  </section>

  <MidPageCta variant="hero" />

  <section class="hub-section">
    <div class="hub-section-inner">
      <h2 id="currency-picture">The currency picture</h2>
      <p>
        You earn in South African rand. UK lenders convert ZAR income to
        sterling for affordability. Most apply a haircut of around 20
        percent, which means a 1,500,000 ZAR package is treated as roughly
        1,200,000 ZAR before the rate kicks in.
      </p>
      <p>
        A smaller group of specialist lenders, accessed through brokers with
        the right relationships, do not apply a haircut at all. This is the
        most important variable on <a href="/expat-mortgages/rates">what you can borrow</a> from South Africa.
      </p>
      <p>
        The rand has been one of the more volatile major currencies against
        sterling, which means lenders treat ZAR income with more caution
        than USD, EUR, or AED. Some lenders apply heavier haircuts than the
        standard 20 percent for ZAR specifically. Lender choice matters
        more here than in most other countries.
      </p>
      <p>
        Try the <a href="/tools/expat-mortgage-calculator">expat mortgage calculator</a>
        to see what each scenario means for your income.
      </p>
    </div>
  </section>

  <PullQuote>
    Lender choice matters more here than in most other countries.
  </PullQuote>

  <section class="hub-section">
    <div class="hub-section-inner">
      <h2 id="common-situations">Common situations</h2>
      <p>British expats applying from South Africa usually fall into one of these:</p>
      <ul>
        <li>
          <strong>Mining, energy, and resources</strong> at Anglo American,
          BHP, and the broader sector. Senior professional roles, often well
          documented.
        </li>
        <li>
          <strong>Banking and financial services</strong> in Johannesburg
          and Cape Town at Standard Bank, FirstRand, and the international
          firms.
        </li>
        <li>
          <strong>Healthcare</strong> at private hospital groups and pharma.
          Doctors and specialists are particularly common in this profile.
        </li>
        <li>
          <strong>Tech and product roles</strong> in Cape Town at
          Naspers/Prosus and the broader Cape Town tech cluster.
        </li>
        <li>
          <strong>Wine, agriculture, and food</strong> in the Western Cape.
        </li>
        <li>
          <strong>Tourism and hospitality</strong> management at the lodge
          groups, hotel chains, and broader sector.
        </li>
      </ul>
    </div>
  </section>

  <section class="hub-section">
    <div class="hub-section-inner">
      <h2 id="lender-requirements">What lenders want to see</h2>
      <p>The <a href="/expat-mortgages/process">standard documentation pack</a> from a South Africa-based applicant:</p>
      <ul>
        <li>Three months of South African bank statements showing salary credits.</li>
        <li>Three months of payslips.</li>
        <li>The most recent two years of SARS IT3(a) employment income tax certificates and ITA34 assessments.</li>
        <li>Employment contract or letter from your employer.</li>
        <li>Evidence of South African residency (ID book or smart card, plus visa documentation if not a citizen).</li>
        <li>Proof of UK address history and any UK property already owned.</li>
        <li>Two years of audited accounts if you are self-employed or run a business.</li>
      </ul>
      <p>
        South Africa has reasonable documentation but the system is
        paper-based in places. Lenders sometimes ask for additional
        verification beyond what is needed in other countries.
      </p>
    </div>
  </section>

  <section class="hub-section">
    <div class="hub-section-inner">
      <h2 id="how-lenders-view">How lenders view South Africa-based applicants</h2>
      <p>
        UK expat lenders that are active in South Africa are comfortable
        with the country, but the lender pool is smaller than for most
        other expat markets. Currency volatility is the main reason. Some
        lenders apply heavier haircuts on ZAR income, others avoid the rand
        entirely.
      </p>
      <p>
        The right lender for a South Africa-based applicant is one with
        current experience of ZAR income, current ZAR-GBP exchange rates
        priced into the haircut sensibly, and a willingness to underwrite
        South African employer documentation efficiently. The wrong lender
        will either decline or apply a haircut that makes the loan size
        uneconomic.
      </p>
      <p>
        Senior professionals at large international employers are generally
        well received. Smaller employers and self-employed applicants face
        more scrutiny.
      </p>
    </div>
  </section>

  <PullQuote>
    The right lender for a South Africa-based applicant prices the haircut
    sensibly.
  </PullQuote>

  <section class="hub-section">
    <div class="hub-section-inner">
      <h2 id="pitfalls">Common pitfalls</h2>
      <p>A few things trip up South Africa-based applications more than they should:</p>
      <ul>
        <li>
          <strong>Excessive haircut.</strong> Some lenders apply 30 to 40
          percent to ZAR income rather than the standard 20 percent. Worth
          knowing in advance.
        </li>
        <li>
          <strong>Currency timing on remortgage.</strong> ZAR-GBP can move
          10 to 15 percent in a few months. Planning ahead matters more
          than in most countries.
        </li>
        <li>
          <strong><a href="/expat-mortgages/deposit">Source of deposit on Reserve Bank approvals.</a></strong>
          Funds taken out of South Africa under the Reserve Bank annual
          allowance need clear documentation.
        </li>
        <li>
          <strong>Self-employment through trusts.</strong> South African
          business structures often involve family trusts. Lenders sometimes
          find these complex to underwrite.
        </li>
        <li>
          <strong>AML on cross-border transfers.</strong> Money moving from
          ZAR to GBP, often through multiple steps, needs a clean paper
          trail.
        </li>
      </ul>
    </div>
  </section>

  <MidPageCta />

  <section class="hub-section">
    <div class="hub-section-inner">
      <h2 id="faqs">Common questions</h2>
      <div class="faq">
        {faqs.map((f) => (
          <>
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </>
        ))}
      </div>
    </div>
  </section>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(faqSchema)}
  />
</HubLayout>
