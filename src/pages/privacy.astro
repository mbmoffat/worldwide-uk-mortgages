---
import T7Layout from '../layouts/T7Layout.astro';

const title = 'Privacy Policy';
const description = 'Privacy policy for UK Mortgages Worldwide.';
import { breadcrumbSchema } from '../lib/schema';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Privacy Policy' },
  ]),
];
---

<T7Layout title={title} description={description} h1="Privacy Policy" schemas={schemas}>
  <p>PLACEHOLDER: full GDPR-compliant privacy policy to be added before launch.</p>
</T7Layout>
