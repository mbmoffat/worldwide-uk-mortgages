---
import T7Layout from '../layouts/T7Layout.astro';
import ContactForm from '../components/ContactForm.astro';

const title = 'Contact';
const description =
  'The fastest way to reach us is the enquiry form on any of our pages. A broker will be in touch, usually the same working day.';
---

<T7Layout title={title} description={description} h1="Contact">
  <p>
    The fastest way to reach us is the enquiry form on any of our pages. Tell
    us where you live, what you earn, and what you want to buy. A broker will
    be in touch, usually the same working day.
  </p>
  <ContactForm />
</T7Layout>
