---
import Layout from '../layouts/Layout.astro';

const description =
  'A UK mortgage enquiry service for British expats and people working at sea. Enquiries referred to FCA-authorised UK mortgage brokers.';
---

<Layout
  title="UK Mortgages for Expats and Seafarers"
  description={description}
>
  <h1>UK mortgages for expats and seafarers</h1>

  <p class="intro">
    {/* PLACEHOLDER COPY: refine before launch */}
    We connect British expats and people working at sea with FCA-authorised UK
    mortgage brokers who specialise in cross-border and offshore income cases.
    Tell us about your situation and we will pass your enquiry to a broker who
    handles applications like yours.
  </p>

  <div class="cta-row">
    <a class="btn" href="/expat-mortgages">UK Mortgages for Expats</a>
    <a class="btn btn-secondary" href="/seafarer-mortgages">UK Mortgages for Seafarers</a>
  </div>

  <section aria-labelledby="who-heading">
    <h2 id="who-heading">Who this site is for</h2>
    <p>
      {/* PLACEHOLDER COPY */}
      British citizens living or working overseas, and UK residents whose
      income comes from work at sea or offshore. Standard UK lenders often
      decline these applications because of foreign currency, residency, or
      employment patterns. The brokers we refer to deal with these cases every
      day.
    </p>
  </section>

  <style>
    .intro {
      font-size: 1.125rem;
      color: var(--muted);
      margin: 0 0 2rem;
    }

    .cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin: 0 0 2.5rem;
    }
  </style>
</Layout>
