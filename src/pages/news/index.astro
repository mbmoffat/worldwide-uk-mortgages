---
import T7Layout from '../../layouts/T7Layout.astro';
import MidPageCta from '../../components/MidPageCta.astro';
import ContactForm from '../../components/ContactForm.astro';
import RiskWarning from '../../components/RiskWarning.astro';
import TerritorialScope from '../../components/TerritorialScope.astro';
import { breadcrumbSchema } from '../../lib/schema';
import { getCollection } from 'astro:content';

const title = 'News - UK Mortgages Worldwide';
const description =
  'Lender criteria changes, rate movements, and other developments that affect expats, non-UK residents, and people earning in foreign currency.';

const articles = (await getCollection('news')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = articles.slice(0, 5);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });

const schemas = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'News', path: '/news' },
  ]),
];
---

<T7Layout
  title={title}
  description={description}
  h1="News"
  eyebrow="LATEST UPDATES"
  schemas={schemas}
>
  <RiskWarning type="residential" />
  <TerritorialScope />

  <div class="news-cards">
    {recent.map((a) => (
      <a class="news-card" href={`/news/${a.slug}`}>
        <p class="news-card-date">{fmt(a.data.pubDate)}</p>
        <h2 class="news-card-title">{a.data.title}</h2>
        <p class="news-card-desc">{a.data.description}</p>
        <span class="news-card-arrow" aria-hidden="true">Read more →</span>
      </a>
    ))}
  </div>

  <p class="news-view-all">
    <a href="/news/archive">View all news →</a>
  </p>

  <MidPageCta />

  <ContactForm />
</T7Layout>

<style is:global>
  .news-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin: 2rem 0 2.5rem;
  }

  .news-card {
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
    border: 1px solid #E8E0D5;
    border-radius: 4px;
    padding: 1.75rem;
    text-decoration: none;
    color: #1A1612;
    transition: transform 0.18s ease, border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .news-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    color: #1A1612;
  }

  .news-card-date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6B6358;
    margin: 0 0 0.5rem;
  }

  .news-card-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: #1A1612;
    line-height: 1.3;
    margin: 0 0 0.625rem;
  }

  .news-card-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: #6B6358;
    line-height: 1.5;
    margin: 0;
  }

  .news-card-arrow {
    color: var(--accent);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    margin-top: 1rem;
    display: inline-block;
    transition: transform 0.18s ease;
  }

  .news-card:hover .news-card-arrow {
    transform: translateX(2px);
  }

  .t7-body .news-view-all {
    text-align: center;
    margin: 0 0 2rem;
    font-family: var(--font-sans);
    font-size: 1rem;
  }

  .t7-body .news-view-all a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .t7-body .news-view-all a:hover {
    text-decoration: underline;
  }
</style>
