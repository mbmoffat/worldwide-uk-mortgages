---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  h1: string;
  subheadline: string;
  eyebrow?: string;
  ctaHeading?: string;
  ctaLeadIn?: string;
}

const {
  title,
  description,
  h1,
  subheadline,
  eyebrow = 'Hub',
  ctaHeading = 'Speak to a specialist',
  ctaLeadIn = 'Contact us here. A mortgage broker will usually respond immediately.',
} = Astro.props;
---

<Layout title={title} description={description}>
  <article class="hub">
    <section class="hub-hero">
      <div class="hub-section-inner">
        <p class="eyebrow">{eyebrow}</p>
        <h1 set:html={h1} />
        <p class="subheadline">{subheadline}</p>
        <div class="hero-actions">
          <a class="btn" href="#contact-form">Send an enquiry</a>
          <span class="hero-meta">
            A mortgage broker will usually respond immediately.
          </span>
        </div>
      </div>
    </section>

    <div class="hub-body">
      <slot />
    </div>

    <section class="hub-cta" id="contact-form" aria-labelledby="cta-heading">
      <div class="hub-section-inner hub-cta-grid">
        <div class="cta-copy">
          <p class="eyebrow">Enquire</p>
          <h2 id="cta-heading">{ctaHeading}</h2>
          <p class="cta-lead">{ctaLeadIn}</p>
        </div>

        <form
          class="enquiry-form"
          action="https://formsubmit.co/mbmoffat@gmail.com"
          method="POST"
        >
          <input
            type="hidden"
            name="_subject"
            value="New enquiry from UK Mortgages Worldwide"
          />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="honeypot" />

          <div class="field">
            <label for="name">Your name</label>
            <input id="name" type="text" name="name" autocomplete="name" required />
          </div>

          <div class="field">
            <label for="email">Email</label>
            <input
              id="email"
              type="email"
              name="email"
              autocomplete="email"
              required
            />
          </div>

          <div class="field">
            <label for="message">What can we help with?</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>

          <button type="submit" class="btn btn-block">Send enquiry</button>

          <p class="form-note">
            We will pass your enquiry to a specialist mortgage broker. We do not
            provide regulated advice on this site.
          </p>
        </form>
      </div>
    </section>
  </article>
</Layout>

<style is:global>
  .hub {
    width: 100%;
    background: var(--bg);
  }

  .hub-section,
  .hub-hero,
  .hub-cta {
    padding: 2rem 1.5rem;
    background: var(--bg);
  }

  .hub-hero {
    padding-top: 3rem;
  }

  @media (min-width: 768px) {
    .hub-section,
    .hub-hero,
    .hub-cta {
      padding: 2.5rem 2rem;
    }

    .hub-hero {
      padding-top: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .hub-section,
    .hub-hero,
    .hub-cta {
      padding: 2.5rem 3rem;
    }

    .hub-hero {
      padding-top: 4.5rem;
    }
  }

  .hub-section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted);
    font-family: var(--font-sans);
    margin: 0 0 1.5rem;
  }

  .hub-hero h1 {
    margin: 0 0 1.25rem;
    max-width: 22ch;
  }

  .subheadline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.0625rem;
    color: var(--text);
    line-height: 1.7;
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.25rem;
    margin-top: 1.75rem;
  }

  .hero-meta {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.7;
  }

  .hub-section h2 {
    margin: 0 0 1.5rem;
    scroll-margin-top: 6rem;
  }

  .hub-section h3 {
    margin: 2rem 0 0.75rem;
  }

  .hub-section h3:first-child {
    margin-top: 0;
  }

  .hub-section p,
  .hub-section ul,
  .hub-section ol {
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 400;
    line-height: 1.7;
  }

  .hub-section ul li::marker {
    color: var(--accent);
  }

  .hub-section a {
    color: var(--accent);
    text-decoration: underline;
  }

  .hub-section a:hover {
    color: var(--accent-hover);
  }

  .hub-section .faq h3 {
    margin: 2rem 0 0.5rem;
  }

  .hub-section .faq h3:first-child {
    margin-top: 0.5rem;
  }

  .hub-cta-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    align-items: start;
  }

  @media (min-width: 880px) {
    .hub-cta-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .cta-copy h2 {
    margin: 0 0 1rem;
    max-width: 16ch;
  }

  .cta-copy .cta-lead {
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 400;
    line-height: 1.7;
    max-width: 38ch;
    margin: 0;
  }

  .enquiry-form {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 600px) {
    .enquiry-form {
      padding: 2rem;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.1rem;
  }

  .field label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .field input,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--text);
    background: #FFFFFF;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 0.85rem;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.5;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .form-note {
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 1rem 0 0;
    line-height: 1.5;
  }

  .btn-block {
    width: 100%;
    padding: 1rem 1.75rem;
  }
</style>
