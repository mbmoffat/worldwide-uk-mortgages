---
import Layout from './Layout.astro';
import MidPageCta from '../components/MidPageCta.astro';

interface RelatedPage {
  eyebrow: string;
  title: string;
  description: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  h1: string;
  subheadline: string;
  eyebrow?: string;
  ctaHeading?: string;
  ctaLeadIn?: string;
  relatedPages?: RelatedPage[];
  relatedPagesHeading?: string;
}

const {
  title,
  description,
  h1,
  subheadline,
  eyebrow = 'Hub',
  ctaHeading = 'Speak to a specialist',
  ctaLeadIn = 'Contact us here. A mortgage broker will usually respond immediately.',
  relatedPages = [],
  relatedPagesHeading = 'Related pages',
} = Astro.props;

const slotHtml = await Astro.slots.render('default');
const sectionCount = (slotHtml.match(/<h2\b/gi) || []).length;
const wordCount = slotHtml
  .replace(/<[^>]+>/g, ' ')
  .split(/\s+/)
  .filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(wordCount / 200));
---

<Layout title={title} description={description}>
  <article class="hub">
    <section class="hub-hero">
      <div class="hub-section-inner">
        <p class="eyebrow">{eyebrow}</p>
        <h1 set:html={h1} />
        <p class="subheadline">{subheadline}</p>

        <MidPageCta variant="hero" />

        <p class="hero-read-meta">{readMinutes} min read · {sectionCount} sections</p>
      </div>
    </section>

    <div class="hub-body">
      <slot />
    </div>

    {relatedPages.length > 0 && (
      <section class="related-pages-section" aria-labelledby="related-pages-heading">
        <div class="hub-section-inner">
          <h2 id="related-pages-heading">{relatedPagesHeading}</h2>
          <div class="related-pages-grid">
            {relatedPages.map((p) => (
              <a class="related-card" href={p.href}>
                <span class="related-card-eyebrow">{p.eyebrow}</span>
                <h3 class="related-card-title">{p.title}</h3>
                <p class="related-card-desc">{p.description}</p>
                <span class="related-card-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="hub-cta" id="contact-form" aria-labelledby="cta-heading">
      <div class="hub-section-inner hub-cta-grid">
        <div class="cta-copy">
          <p class="eyebrow">Enquire</p>
          <h2 id="cta-heading">{ctaHeading}</h2>
          <p class="cta-lead">{ctaLeadIn}</p>
        </div>

        <form
          class="enquiry-form"
          action="https://formsubmit.co/mbmoffat@gmail.com"
          method="POST"
        >
          <input
            type="hidden"
            name="_subject"
            value="New enquiry from UK Mortgages Worldwide"
          />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="honeypot" />

          <div class="field">
            <label for="name">Your name</label>
            <input id="name" type="text" name="name" autocomplete="name" required />
          </div>

          <div class="field">
            <label for="email">Email</label>
            <input
              id="email"
              type="email"
              name="email"
              autocomplete="email"
              required
            />
          </div>

          <div class="field">
            <label for="message">What can we help with?</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>

          <button type="submit" class="btn btn-block">Send enquiry</button>

          <p class="form-note">
            We will pass your enquiry to a specialist mortgage broker. We do not
            provide regulated advice on this site.
          </p>
        </form>
      </div>
    </section>
  </article>
</Layout>

<style is:global>
  .hub {
    width: 100%;
    background: var(--bg);
  }

  .hub-section,
  .hub-hero,
  .hub-cta {
    padding: 2rem 1.5rem;
    background: var(--bg);
  }

  .hub-hero {
    padding-top: 3rem;
  }

  @media (min-width: 768px) {
    .hub-section,
    .hub-hero,
    .hub-cta {
      padding: 2.5rem 2rem;
    }

    .hub-hero {
      padding-top: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .hub-section,
    .hub-hero,
    .hub-cta {
      padding: 2.5rem 3rem;
    }

    .hub-hero {
      padding-top: 4.5rem;
    }
  }

  .hub-section-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted);
    font-family: var(--font-sans);
    margin: 0 0 1.5rem;
  }

  .hub-hero h1 {
    margin: 0 0 1.25rem;
    max-width: 22ch;
  }

  .subheadline {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.0625rem;
    color: var(--text);
    line-height: 1.7;
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  .hero-cta-block {
    max-width: 600px;
    margin: 2.5rem auto 0;
    text-align: center;
  }

  .hub-section h2 {
    margin: 0 0 1.5rem;
    scroll-margin-top: 6rem;
  }

  .hub-section h3 {
    margin: 2rem 0 0.75rem;
  }

  .hub-section h3:first-child {
    margin-top: 0;
  }

  .hub-section p,
  .hub-section ul,
  .hub-section ol {
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 400;
    line-height: 1.7;
  }

  .hub-section ul li::marker {
    color: var(--accent);
  }

  .hub-section a {
    color: var(--accent);
    text-decoration: underline;
  }

  .hub-section a:hover {
    color: var(--accent-hover);
  }

  .hub-section .faq h3 {
    margin: 2rem 0 0.5rem;
  }

  .hub-section .faq h3:first-child {
    margin-top: 0.5rem;
  }

  .hub-cta-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    align-items: start;
  }

  @media (min-width: 880px) {
    .hub-cta-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .cta-copy h2 {
    margin: 0 0 1rem;
    max-width: 16ch;
  }

  .cta-copy .cta-lead {
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 400;
    line-height: 1.7;
    max-width: 38ch;
    margin: 0;
  }

  .enquiry-form {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 600px) {
    .enquiry-form {
      padding: 2rem;
    }
  }

  .field {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.1rem;
  }

  .field label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .field input,
  .field textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--text);
    background: #FFFFFF;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 0.85rem;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.5;
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .form-note {
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 1rem 0 0;
    line-height: 1.5;
  }

  .btn-block {
    width: 100%;
    padding: 1rem 1.75rem;
  }

  .hero-read-meta {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: #6B6358;
    line-height: 1.5;
    margin: 1.5rem 0 0;
    text-align: center;
  }

  /* Pull quote */
  .pull-quote-wrap {
    padding: 0 1.5rem;
    background: var(--bg);
  }

  @media (min-width: 768px) {
    .pull-quote-wrap {
      padding: 0 2rem;
    }
  }

  @media (min-width: 1024px) {
    .pull-quote-wrap {
      padding: 0 3rem;
    }
  }

  .pull-quote {
    max-width: var(--content-width);
    margin: 3.5rem auto;
    padding: 0 0 0 1.5rem;
    border-left: 3px solid var(--accent);
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.3;
    color: #1A1612;
  }

  @media (min-width: 768px) {
    .pull-quote {
      font-size: 1.875rem;
    }
  }

  /* Mid-page CTA */
  .mid-cta {
    background: #FBF6EF;
    border-top: 1px solid #E8E0D5;
    border-bottom: 1px solid #E8E0D5;
    padding: 3rem 1.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .mid-cta {
      padding: 3rem 2rem;
    }
  }

  .mid-cta-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .mid-cta-heading {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.3;
    color: #1A1612;
    margin: 0 0 1rem;
  }

  .mid-cta-body {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.0625rem;
    color: #1A1612;
    line-height: 1.7;
    margin: 0;
  }

  .mid-cta-btn {
    margin-top: 1.5rem;
  }

  .mid-cta-note {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: #6B6358;
    margin: 0.75rem 0 0;
    line-height: 1.5;
  }

  /* Related pages */
  .related-pages-section {
    padding: 2rem 1.5rem;
    background: var(--bg);
  }

  @media (min-width: 768px) {
    .related-pages-section {
      padding: 2.5rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .related-pages-section {
      padding: 2.5rem 3rem;
    }
  }

  .related-pages-section .hub-section-inner {
    max-width: var(--wide-width);
  }

  .related-pages-section h2 {
    margin: 0 0 2rem;
  }

  .related-pages-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .related-pages-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
    border: 1px solid #E8E0D5;
    border-radius: 4px;
    padding: 1.75rem;
    text-decoration: none;
    color: #1A1612;
    transition: transform 0.18s ease, border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .related-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    color: #1A1612;
  }

  .related-card-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6B6358;
    margin: 0 0 0.5rem;
  }

  .related-card-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: #1A1612;
    line-height: 1.3;
    margin: 0 0 0.625rem;
  }

  .related-card-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: #6B6358;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card-arrow {
    color: var(--accent);
    font-size: 1.125rem;
    margin-top: 1rem;
    display: inline-block;
    transition: transform 0.18s ease;
  }

  .related-card:hover .related-card-arrow {
    transform: translateX(2px);
  }
</style>
