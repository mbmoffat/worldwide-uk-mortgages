---
import Layout from './Layout.astro';
import RelatedCard from '../components/RelatedCard.astro';
import ContactForm from '../components/ContactForm.astro';

interface RelatedPage {
  eyebrow: string;
  title: string;
  description: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  h1: string;
  subheadline: string;
  eyebrow?: string;
  ctaHeading?: string;
  ctaLeadIn?: string;
  relatedPages?: RelatedPage[];
  relatedPagesHeading?: string;
  articleClass?: string;
}

const {
  title,
  description,
  h1,
  subheadline,
  eyebrow = 'Hub',
  relatedPages = [],
  relatedPagesHeading = 'Related pages',
  articleClass,
} = Astro.props;

const slotHtml = await Astro.slots.render('default');
const sectionCount = (slotHtml.match(/<h2\b/gi) || []).length;
const wordCount = slotHtml
  .replace(/<[^>]+>/g, ' ')
  .split(/\s+/)
  .filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(wordCount / 200));
---

<Layout title={title} description={description}>
  <article class:list={["hub", articleClass]}>
    <section class="hub-hero">
      <div class="hub-section-inner">
        <p class="eyebrow">{eyebrow}</p>
        <h1 set:html={h1} />
        <p class="subheadline">{subheadline}</p>

        <p class="hero-read-meta">{readMinutes} min read · {sectionCount} sections</p>
      </div>
    </section>

    <div class="hub-body">
      <slot />
    </div>

    <ContactForm />

    {relatedPages.length > 0 && (
      <section class="related-pages-section" aria-labelledby="related-pages-heading">
        <div class="hub-section-inner">
          <h2 id="related-pages-heading">{relatedPagesHeading}</h2>
          <div class="related-pages-grid">
            {relatedPages.map((p) => (
              <RelatedCard
                eyebrow={p.eyebrow}
                title={p.title}
                description={p.description}
                href={p.href}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</Layout>
