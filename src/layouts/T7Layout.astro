---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  h1: string;
  eyebrow?: string;
  lead?: string;
  schemas?: Record<string, any>[];
}

const { title, description, h1, eyebrow, lead, schemas = [] } = Astro.props;
---

<Layout title={title} description={description} schemas={schemas}>
  <article class="t7">
    <div class="t7-inner">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{h1}</h1>
      {lead && <p class="t7-lead">{lead}</p>}
      <div class="t7-body">
        <slot />
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .t7 {
    background: var(--bg);
    padding: 3rem 1.5rem 4rem;
  }

  @media (min-width: 768px) {
    .t7 {
      padding: 4rem 2rem 5rem;
    }
  }

  @media (min-width: 1024px) {
    .t7 {
      padding: 4.5rem 3rem 5rem;
    }
  }

  .t7-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .t7 h1 {
    margin: 0 0 1.25rem;
  }

  .t7-lead {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.1875rem;
    color: #1A1612;
    line-height: 1.5;
    letter-spacing: -0.01em;
    margin: 0 0 2rem;
  }

  .t7-body {
    font-family: var(--font-body);
    font-size: 1.1875rem;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #1A1612;
  }

  .t7-body h2 {
    margin: 2.5rem 0 1rem;
    scroll-margin-top: 6rem;
  }

  .t7-body h2:first-child {
    margin-top: 0;
  }

  .t7-body h3 {
    margin: 2rem 0 0.75rem;
  }

  .t7-body p {
    margin: 0 0 1.25rem;
  }

  .t7-body ul,
  .t7-body ol {
    margin: 0 0 1.25rem;
    padding-left: 1.25rem;
  }

  .t7-body ul li::marker {
    color: var(--accent);
  }

  .t7-body a {
    color: var(--accent);
    text-decoration: underline;
  }

  .t7-body a:hover {
    color: var(--accent-hover);
  }

  .t7-body a.btn {
    color: #FFFFFF;
    text-decoration: none;
  }

  .t7-body a.btn:hover {
    color: #FFFFFF;
  }

  .t7-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .t7-callout {
    background: #FFFFFF;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    margin: 0 0 1.25rem;
    font-size: 0.9375rem;
    color: var(--muted);
    font-style: italic;
  }
</style>
