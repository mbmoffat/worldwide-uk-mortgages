---
import { SITE_NAME } from '../../astro.config.mjs';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  schemas?: Record<string, any>[];
}

const { title, description, ogTitle, ogDescription, schemas = [] } = Astro.props;
const pageTitle = title ? `${title} | ${SITE_NAME}` : SITE_NAME;
const socialTitle = ogTitle ?? title ?? SITE_NAME;
const socialDescription = ogDescription ?? description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL('/og-default.png', Astro.site).toString();
const currentYear = new Date().getFullYear();

const mortgages = [
  { label: 'UK Mortgages for Expats', href: '/expat-mortgages' },
  { label: 'UK Mortgages for Non-UK Residents', href: '/non-uk-resident-mortgages' },
  { label: 'UK Mortgages with Foreign Income', href: '/uk-mortgage-foreign-income' },
  { label: 'UK Mortgages Living Abroad', href: '/uk-mortgage-living-abroad' },
  { label: 'Foreign Nationals in UK', href: '/uk-mortgage-for-foreign-nationals' },
  { label: 'Seafarer Mortgages', href: '/seafarer-mortgages' },
  { label: 'Expat Buy-to-Let', href: '/expat-mortgages/buy-to-let' },
  { label: 'Non-UK Resident Buy-to-Let', href: '/non-uk-resident-mortgages/buy-to-let' },
];

const countries = [
  { label: 'Australia', href: '/expat-mortgages/countries/australia' },
  { label: 'Canada', href: '/expat-mortgages/countries/canada' },
  { label: 'Dubai', href: '/expat-mortgages/countries/dubai' },
  { label: 'Germany', href: '/expat-mortgages/countries/germany' },
  { label: 'Hong Kong', href: '/expat-mortgages/countries/hong-kong' },
  { label: 'Netherlands', href: '/expat-mortgages/countries/netherlands' },
  { label: 'New Zealand', href: '/expat-mortgages/countries/new-zealand' },
  { label: 'Norway', href: '/expat-mortgages/countries/norway' },
  { label: 'Qatar', href: '/expat-mortgages/countries/qatar' },
  { label: 'Saudi Arabia', href: '/expat-mortgages/countries/saudi-arabia' },
  { label: 'Singapore', href: '/expat-mortgages/countries/singapore' },
  { label: 'South Africa', href: '/expat-mortgages/countries/south-africa' },
  { label: 'Switzerland', href: '/expat-mortgages/countries/switzerland' },
  { label: 'USA', href: '/expat-mortgages/countries/usa' },
];

const calculators = [
  { label: 'Stamp Duty Calculator', href: '/tools/stamp-duty-calculator' },
  { label: 'Expat Mortgage Calculator', href: '/tools/expat-mortgage-calculator' },
];

const guides = [
  { label: 'Returning to the UK', href: '/expat-mortgages/returning-to-uk' },
  { label: 'No UK Credit History', href: '/expat-mortgages/no-uk-credit-history' },
  { label: 'Expat Mortgage Rates', href: '/expat-mortgages/rates' },
  { label: 'Expat Mortgage Deposit', href: '/expat-mortgages/deposit' },
  { label: 'Expat Remortgaging', href: '/expat-mortgages/remortgage' },
  { label: 'Buy-to-Let from Abroad', href: '/expat-mortgages/buy-to-let-from-abroad' },
  { label: 'The Application Process', href: '/expat-mortgages/process' },
  { label: 'Expat Mortgage Broker', href: '/expat-mortgage-broker' },
  { label: 'Non-Resident Landlord Scheme', href: '/guides/non-resident-landlord-scheme' },
  { label: 'NRL1 Form Explained', href: '/guides/nrl1-form-explained' },
  { label: 'Buying UK Property from Overseas', href: '/guides/buying-uk-property-from-overseas' },
  { label: 'Expat First-Time Buyer', href: '/expat-mortgages/first-time-buyer' },
  { label: 'Expat BTL Rates', href: '/expat-mortgages/buy-to-let/rates' },
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={socialTitle} />
    {socialDescription && <meta property="og:description" content={socialDescription} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    {socialDescription && <meta name="twitter:description" content={socialDescription} />}
    <meta name="twitter:image" content={ogImage} />

    {schemas.map((s) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/">
          <span class="logo-wordmark">UK Mortgages Worldwide</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <div class="nav-dropdown">
            <button
              type="button"
              class="nav-dropdown-trigger"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="nav-mortgages-menu"
            >
              Mortgages
              <span class="nav-dropdown-caret" aria-hidden="true">▾</span>
            </button>
            <div class="nav-dropdown-menu" id="nav-mortgages-menu" role="menu">
              {mortgages.map((item) => (
                <a href={item.href} role="menuitem">{item.label}</a>
              ))}
            </div>
          </div>

          <div class="nav-dropdown">
            <button
              type="button"
              class="nav-dropdown-trigger"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="nav-countries-menu"
            >
              Countries
              <span class="nav-dropdown-caret" aria-hidden="true">▾</span>
            </button>
            <div class="nav-dropdown-menu" id="nav-countries-menu" role="menu">
              {countries.map((item) => (
                <a href={item.href} role="menuitem">{item.label}</a>
              ))}
            </div>
          </div>

          <div class="nav-dropdown">
            <button
              type="button"
              class="nav-dropdown-trigger"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="nav-calculators-menu"
            >
              Calculators
              <span class="nav-dropdown-caret" aria-hidden="true">▾</span>
            </button>
            <div class="nav-dropdown-menu" id="nav-calculators-menu" role="menu">
              {calculators.map((item) => (
                <a href={item.href} role="menuitem">{item.label}</a>
              ))}
            </div>
          </div>

          <div class="nav-dropdown">
            <button
              type="button"
              class="nav-dropdown-trigger"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="nav-guides-menu"
            >
              Guides
              <span class="nav-dropdown-caret" aria-hidden="true">▾</span>
            </button>
            <div class="nav-dropdown-menu" id="nav-guides-menu" role="menu">
              {guides.map((item) => (
                <a href={item.href} role="menuitem">{item.label}</a>
              ))}
            </div>
          </div>

          <a href="/about">About</a>
          <a class="nav-cta" href="#contact-form">Contact</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <span class="brand-name">UK Mortgages Worldwide</span>
            <p class="footer-tag">
              UK mortgages for people who live, work or earn outside the UK.
            </p>
          </div>
          <div class="footer-disclosure">
            <ul class="footer-links">
              <li><a href="/about">About</a></li>
              <li><a href="/contact">Contact</a></li>
              <li><a href="/introducer-disclosure">Introducer disclosure</a></li>
              <li><a href="/privacy">Privacy</a></li>
              <li><a href="/cookies">Cookies</a></li>
              <li><a href="/terms">Terms</a></li>
              <li><a href="/sitemap">Sitemap</a></li>
            </ul>
            <p class="footer-disclaimer">
              We do not provide regulated mortgage advice. We pass enquiries to
              FCA-authorised mortgage brokers.
            </p>
          </div>
        </div>
        <div class="footer-bottom">
          <p class="copyright">&copy; {currentYear} UK Mortgages Worldwide.</p>
        </div>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #FBF6EF;
        --surface: #FFFFFF;
        --text: #1A1612;
        --muted: #6B6358;
        --border: #E8E0D5;
        --accent: #8B2331;
        --accent-hover: #6E1A26;
        --accent-soft: rgba(139, 35, 49, 0.1);
        --shadow-sm: 0 1px 2px rgba(26, 22, 18, 0.04);
        --shadow-md: 0 8px 24px rgba(26, 22, 18, 0.08);
        --shadow-lg: 0 20px 60px rgba(26, 22, 18, 0.14);
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 16px;
        --radius-pill: 999px;
        --content-width: 820px;
        --wide-width: 1120px;
        --font-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI',
          Roboto, 'Helvetica Neue', Arial, sans-serif;
        --font-body: 'Lora', Georgia, 'Times New Roman', serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.7;
        color: var(--text);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        font-family: var(--font-body);
        font-weight: 400;
        font-size: 1.1875rem;
        line-height: 1.5;
        letter-spacing: -0.01em;
        color: #1A1612;
        background: var(--bg);
        overflow-x: clip;
      }

      main {
        flex: 1;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--font-serif);
        color: var(--text);
        margin: 0;
      }

      h1 {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.1;
        text-align: center;
      }

      h2 {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.2;
      }

      h3 {
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1.3;
      }

      @media (min-width: 768px) {
        h1 {
          font-size: 3.25rem;
        }

        h2 {
          font-size: 1.875rem;
        }

        h3 {
          font-size: 1.375rem;
        }
      }

      .nobr {
        white-space: nowrap;
      }

      p {
        margin: 0 0 1.25rem;
        color: var(--text);
      }

      a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.2em;
      }

      a:hover {
        color: var(--accent-hover);
      }

      strong {
        font-weight: 600;
        color: var(--text);
      }

      hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 3rem 0;
      }

      ul,
      ol {
        padding-left: 1.25rem;
        margin: 0 0 1.25rem;
      }

      ul li,
      ol li {
        margin-bottom: 0.5rem;
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: auto;
      }

      .skip-link:focus {
        position: fixed;
        left: 1rem;
        top: 1rem;
        background: var(--accent);
        color: #fff;
        padding: 0.5rem 0.875rem;
        z-index: 200;
        border-radius: var(--radius-sm);
        text-decoration: none;
      }

      .site-header {
        background: var(--bg);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 50;
      }

      .header-inner {
        max-width: var(--wide-width);
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 1.05rem 1.5rem;
      }

      @media (min-width: 768px) {
        .header-inner {
          padding: 1.25rem 2rem;
        }
      }

      @media (min-width: 1024px) {
        .header-inner {
          padding: 1.25rem 3rem;
        }
      }

      .brand {
        text-decoration: none;
        color: var(--text);
        line-height: 1;
      }

      .brand:hover {
        color: var(--text);
        text-decoration: none;
      }

      .logo-wordmark {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        font-size: 1.5rem;
        letter-spacing: -0.01em;
        color: #1A1612;
        line-height: 1;
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 1.75rem;
      }

      .site-nav a {
        text-decoration: none;
        color: var(--text);
        font-family: 'Lora', serif;
        font-size: 0.9375rem;
        font-weight: 700;
        letter-spacing: 0;
      }

      .site-nav a:hover {
        color: var(--accent);
      }

      .site-nav .nav-cta {
        background: var(--accent);
        color: #FFFFFF;
        padding: 0.625rem 1.25rem;
        border-radius: var(--radius-pill);
        font-family: 'Lora', serif;
        font-style: normal;
        font-size: 0.9375rem;
        font-weight: 700;
        letter-spacing: 0;
        transition: background 0.15s ease;
      }

      .site-nav .nav-cta:hover {
        background: var(--accent-hover);
        color: #FFFFFF;
      }

      /* Header mega-menu dropdowns. Desktop: hover-open with absolute
         positioning. Mobile: tap-to-toggle with inline expansion. JS
         toggles data-open on the wrapper for keyboard / tap support. */
      .nav-dropdown {
        position: relative;
      }

      .nav-dropdown-trigger {
        background: transparent;
        border: 0;
        padding: 0;
        cursor: pointer;
        font-family: 'Lora', serif;
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: 0;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      .nav-dropdown-trigger:hover,
      .nav-dropdown-trigger:focus-visible {
        color: var(--accent);
      }

      .nav-dropdown-caret {
        font-size: 0.7rem;
        transition: transform 0.15s ease;
      }

      .nav-dropdown[data-open="true"] .nav-dropdown-caret {
        transform: rotate(180deg);
      }

      .nav-dropdown-menu {
        display: none;
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 0.5rem;
        background: #FBF6EF;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-md);
        min-width: 280px;
        padding: 0.5rem 0;
        z-index: 100;
      }

      @media (hover: hover) {
        .nav-dropdown:hover > .nav-dropdown-menu {
          display: block;
        }
      }

      .nav-dropdown[data-open="true"] > .nav-dropdown-menu {
        display: block;
      }

      .nav-dropdown-menu a {
        display: block;
        padding: 0.6rem 1rem;
        text-decoration: none;
        color: var(--text);
        font-family: 'Lora', serif;
        font-size: 0.9375rem;
        font-weight: 700;
        letter-spacing: 0;
        white-space: nowrap;
      }

      .nav-dropdown-menu a:hover,
      .nav-dropdown-menu a:focus-visible {
        background: var(--accent-soft);
        color: var(--accent);
        outline: none;
      }

      .nav-dropdown-heading {
        font-family: var(--font-sans);
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        padding: 0.6rem 1rem 0.25rem;
        margin: 0.75rem 0 0;
      }

      .nav-dropdown-menu > .nav-dropdown-heading:first-child {
        margin-top: 0;
      }

      @media (max-width: 720px) {
        .header-inner {
          flex-wrap: wrap;
          row-gap: 0.75rem;
        }

        .site-nav {
          order: 2;
          width: 100%;
          flex-wrap: wrap;
          gap: 0.75rem 1.25rem;
          align-items: center;
        }

        .nav-dropdown-menu {
          position: static;
          margin-top: 0.5rem;
          background: transparent;
          border: none;
          box-shadow: none;
          padding: 0;
          min-width: 0;
          width: 100%;
        }

        .nav-dropdown-menu a {
          padding: 0.5rem 0 0.5rem 1rem;
          white-space: normal;
        }

        .nav-dropdown-heading {
          padding: 0.5rem 0 0.25rem 1rem;
        }
      }

      .site-footer {
        background: var(--bg);
        border-top: 1px solid var(--border);
        padding: 4rem 1.5rem 2.5rem;
        font-family: 'Lora', serif;
        font-weight: 400;
        font-size: 0.875rem;
        color: var(--muted);
      }

      @media (min-width: 768px) {
        .site-footer {
          padding: 4rem 2rem 2.5rem;
        }
      }

      @media (min-width: 1024px) {
        .site-footer {
          padding: 4rem 3rem 2.5rem;
        }
      }

      .footer-inner {
        max-width: var(--wide-width);
        margin: 0 auto;
      }

      .footer-top {
        display: grid;
        gap: 2.5rem;
        grid-template-columns: 1fr;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid var(--border);
      }

      @media (min-width: 768px) {
        .footer-top {
          grid-template-columns: 1fr 1fr;
          gap: 4rem;
        }
      }

      .footer-brand .brand-name {
        font-family: 'Lora', serif;
        font-size: 1.375rem;
        font-weight: 700;
        color: var(--text);
        display: block;
        margin-bottom: 0.625rem;
      }

      .footer-tag {
        color: var(--muted);
        font-size: 0.875rem;
        max-width: 36ch;
        margin: 0;
      }

      .footer-disclaimer {
        margin: 1.25rem auto 0;
        font-size: 0.875rem;
        color: var(--muted);
        max-width: 52ch;
        text-align: center;
      }

      .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.25rem;
      }

      .footer-links li {
        margin: 0;
      }

      .footer-links a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.875rem;
      }

      .footer-links a:hover {
        color: var(--accent);
        text-decoration: underline;
      }

      .footer-bottom {
        padding-top: 1.75rem;
      }

      .footer-bottom .copyright {
        margin: 0;
        font-size: 0.875rem;
        color: var(--muted);
      }

      .btn {
        display: block;
        box-sizing: border-box;
        width: 280px;
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
        font-family: 'Lora', serif;
        font-style: normal;
        font-size: 1rem;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0;
        padding: 0.95rem 1.5rem;
        border-radius: var(--radius-pill);
        text-decoration: none;
        border: 1px solid transparent;
        background: var(--accent);
        color: #FFFFFF;
        cursor: pointer;
        transition: background 0.15s ease, transform 0.15s ease,
          box-shadow 0.15s ease;
      }

      @media (max-width: 599px) {
        .btn {
          width: 100%;
        }
      }

      .btn:hover {
        background: var(--accent-hover);
        color: #FFFFFF;
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
      }

      .btn-secondary {
        background: transparent;
        color: var(--accent);
        border-color: var(--accent);
      }

      .btn-secondary:hover {
        background: var(--accent);
        color: #FFFFFF;
      }

      /* Page article wrapper, shared by HubLayout and the homepage */
      .hub {
        width: 100%;
        background: var(--bg);
      }

      /* No vertical padding on hub-section/hub-hero. All vertical rhythm
         comes from element margins to prevent compounding. Horizontal
         padding remains for the column. Hero keeps a top padding so the
         page breathes from the sticky header. */
      .hub-section,
      .hub-hero {
        padding: 0 1.5rem;
        background: var(--bg);
      }

      .hub-hero {
        padding-top: 3rem;
      }

      @media (min-width: 768px) {
        .hub-section,
        .hub-hero {
          padding: 0 2rem;
        }

        .hub-hero {
          padding-top: 4rem;
        }
      }

      @media (min-width: 1024px) {
        .hub-section,
        .hub-hero {
          padding: 0 3rem;
        }

        .hub-hero {
          padding-top: 4.5rem;
        }
      }

      .hub-section-inner {
        max-width: var(--content-width);
        margin: 0 auto;
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--muted);
        font-family: var(--font-sans);
        margin: 0 0 1.5rem;
      }

      .hub-hero h1 {
        margin: 0 0 1.25rem;
      }

      .subheadline {
        font-family: var(--font-body);
        font-weight: 400;
        font-size: 1.1875rem;
        color: #1A1612;
        line-height: 1.5;
        letter-spacing: -0.01em;
        margin: 0 0 1.5rem;
      }

      .hub-section h2 {
