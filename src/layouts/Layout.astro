    <script is:inline>
      (function () {
        var dropdowns = Array.prototype.slice.call(
          document.querySelectorAll('.nav-dropdown')
        );
        if (!dropdowns.length) return;

        function close(dd) {
          dd.dataset.open = 'false';
          var t = dd.querySelector('.nav-dropdown-trigger');
          if (t) t.setAttribute('aria-expanded', 'false');
        }

        function open(dd) {
          dd.dataset.open = 'true';
          var t = dd.querySelector('.nav-dropdown-trigger');
          if (t) t.setAttribute('aria-expanded', 'true');
        }

        function closeOthers(except) {
          dropdowns.forEach(function (dd) {
            if (dd !== except) close(dd);
          });
        }

        dropdowns.forEach(function (dd) {
          var trigger = dd.querySelector('.nav-dropdown-trigger');
          var items = Array.prototype.slice.call(
            dd.querySelectorAll('.nav-dropdown-menu a')
          );

          trigger.addEventListener('click', function (e) {
            e.stopPropagation();
            var isOpen = dd.dataset.open === 'true';
            closeOthers(dd);
            if (isOpen) close(dd);
            else open(dd);
          });

          trigger.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowDown') {
              e.preventDefault();
              open(dd);
              if (items[0]) items[0].focus();
            } else if (e.key === 'Escape') {
              close(dd);
            }
          });

          items.forEach(function (item, i) {
            item.addEventListener('keydown', function (e) {
              if (e.key === 'ArrowDown') {
                e.preventDefault();
                var next = items[(i + 1) % items.length];
                if (next) next.focus();
              } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                var prev = items[(i - 1 + items.length) % items.length];
                if (prev) prev.focus();
              } else if (e.key === 'Escape') {
                e.preventDefault();
                close(dd);
                trigger.focus();
              }
            });
          });
        });

        document.addEventListener('click', function (e) {
          dropdowns.forEach(function (dd) {
            if (!dd.contains(e.target)) close(dd);
          });
        });

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            dropdowns.forEach(close);
          }
        });
      })();
    </script>
