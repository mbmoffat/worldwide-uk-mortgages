---
interface Props {
  heading?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaNote?: string;
  variant?: 'hero' | 'section';
}

const {
  heading = 'Talk to a broker about your situation',
  ctaLabel = 'Talk to a broker',
  ctaHref = '#contact-form',
  ctaNote = 'A mortgage broker will usually respond immediately.',
  variant = 'section',
} = Astro.props;
---

{variant === 'section' ? (
  <section class="cta-block">
    <div class="cta-block-inner">
      <h3 class="cta-block-heading">{heading}</h3>
      <a class="btn cta-block-btn" href={ctaHref}>{ctaLabel}</a>
      <p class="cta-block-note">{ctaNote}</p>
    </div>
  </section>
) : (
  <div class="cta-block cta-block--hero">
    <div class="cta-block-inner">
      <h3 class="cta-block-heading">{heading}</h3>
      <a class="btn cta-block-btn" href={ctaHref}>{ctaLabel}</a>
      <p class="cta-block-note">{ctaNote}</p>
    </div>
  </div>
)}

<style is:global>
  .cta-block {
    border-top: 1px solid #E8E0D5;
    border-bottom: 1px solid #E8E0D5;
    padding: 2rem 1.5rem;
    margin: 1.5rem 0 0;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cta-block {
      padding: 2rem 2rem;
    }
  }

  .cta-block + .contact {
    padding-top: 2rem !important;
  }

  /* Hero variant breaks out of the constrained content column so the
     dividers run edge to edge of the viewport. */
  .cta-block--hero {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  .cta-block-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-block-heading {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.3;
    color: #1A1612;
    margin: 0;
  }

  .cta-block-btn {
    margin-top: 1rem;
  }

  .cta-block-note {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: #6B6358;
    margin: 1.25rem 0 0;
    line-height: 1.5;
  }
</style>
