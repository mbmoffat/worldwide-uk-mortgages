---
interface Props {
  heading?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaNote?: string;
  variant?: 'hero' | 'section';
}

const {
  heading = 'Talk to a broker about your situation',
  body = 'A specialist will tell you within one conversation which lenders are likely to lend to you, what deposit you will need, and what rate range to expect.',
  ctaLabel = 'Send an enquiry',
  ctaHref = '#contact-form',
  ctaNote = 'A mortgage broker will usually respond immediately.',
  variant = 'section',
} = Astro.props;
---

{variant === 'section' ? (
  <section class="cta-block">
    <div class="cta-block-inner">
      <h3 class="cta-block-heading">{heading}</h3>
      <p class="cta-block-body">{body}</p>
      <a class="btn cta-block-btn" href={ctaHref}>{ctaLabel}</a>
      <p class="cta-block-note">{ctaNote}</p>
    </div>
  </section>
) : (
  <div class="cta-block cta-block--hero">
    <div class="cta-block-inner">
      <h3 class="cta-block-heading">{heading}</h3>
      <p class="cta-block-body">{body}</p>
      <a class="btn cta-block-btn" href={ctaHref}>{ctaLabel}</a>
      <p class="cta-block-note">{ctaNote}</p>
    </div>
  </div>
)}

<style is:global>
  .cta-block {
    border-top: 1px solid #E8E0D5;
    border-bottom: 1px solid #E8E0D5;
    padding: 3rem 1.5rem;
    margin: 0;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cta-block {
      padding: 3rem 2rem;
    }
  }

  /* Hero variant breaks out of the constrained content column so the
     dividers run edge to edge of the viewport. */
  .cta-block--hero {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  .cta-block-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-block-heading {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.3;
    color: #1A1612;
    margin: 0 0 0.75rem;
  }

  .cta-block-body {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.1875rem;
    color: #1A1612;
    line-height: 1.5;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .cta-block-btn {
    margin-top: 1.5rem;
  }

  .cta-block-note {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: #6B6358;
    margin: 0.75rem 0 0;
    line-height: 1.5;
  }
</style>
