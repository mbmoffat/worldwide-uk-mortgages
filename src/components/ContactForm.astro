---
// Submits to /api/enquiry, a Vercel edge function that forwards to
// formsubmit.co (zero-config). On API failure, the form falls back to
// a mailto: link pre-populated with the user's input.
const MAILTO = 'mbmoffat@gmail.com';
---

<section class="contact" id="contact-form" aria-labelledby="contact-form-heading">
  <div class="contact-inner">
    <h2 id="contact-form-heading">Send an enquiry</h2>
    <p class="contact-lead">Fill in a few details. A broker will be in touch.</p>

    <form
      class="contact-form"
      action="/api/enquiry"
      method="POST"
      data-mailto={MAILTO}
      novalidate
    >
      <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="contact-honeypot" />

      <div class="contact-field">
        <label for="cf-name">Name <span class="contact-required" aria-hidden="true">*</span></label>
        <input id="cf-name" type="text" name="name" autocomplete="name" required />
      </div>

      <div class="contact-field">
        <label for="cf-email">Email <span class="contact-required" aria-hidden="true">*</span></label>
        <input id="cf-email" type="email" name="email" autocomplete="email" required />
      </div>

      <div class="contact-field">
        <label for="cf-phone">WhatsApp or phone number</label>
        <input id="cf-phone" type="tel" name="phone" autocomplete="tel" />
      </div>

      <div class="contact-field">
        <label for="cf-location">Where do you live?</label>
        <input id="cf-location" type="text" name="location" />
      </div>

      <div class="contact-field">
        <label for="cf-message">Tell us about your situation <span class="contact-required" aria-hidden="true">*</span></label>
        <textarea id="cf-message" name="message" rows="4" required></textarea>
      </div>

      <button type="submit" class="btn contact-submit">Send</button>

      <p class="contact-note">
        We will pass your enquiry to a specialist mortgage broker. We do not
        provide regulated mortgage advice.
      </p>

      <p class="contact-status contact-status--success" role="status" hidden>
        Thanks. Your enquiry is on its way to a broker. Expect a reply within
        one working day.
      </p>
      <p class="contact-status contact-status--error" role="alert" hidden>
        Something went wrong sending your enquiry.
        <a class="contact-mailto" href={`mailto:${MAILTO}`}>Email us instead</a>
        and we will pick it up.
      </p>
    </form>
  </div>
</section>

<script is:inline>
  (function () {
    var forms = document.querySelectorAll('form.contact-form');
    forms.forEach(function (form) {
      var btn = form.querySelector('.contact-submit');
      var ok = form.querySelector('.contact-status--success');
      var err = form.querySelector('.contact-status--error');
      var mailto = form.getAttribute('data-mailto') || '';

      function buildMailto() {
        var fd = new FormData(form);
        var lines = [
          'Name: ' + (fd.get('name') || ''),
          'Email: ' + (fd.get('email') || ''),
          'Phone: ' + (fd.get('phone') || ''),
          'Location: ' + (fd.get('location') || ''),
          '',
          'Message:',
          String(fd.get('message') || ''),
        ];
        var subject = 'Enquiry from UK Mortgages Worldwide';
        return (
          'mailto:' + mailto +
          '?subject=' + encodeURIComponent(subject) +
          '&body=' + encodeURIComponent(lines.join('\n'))
        );
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (!form.reportValidity()) return;

        ok.hidden = true;
        err.hidden = true;
        btn.disabled = true;
        var original = btn.textContent;
        btn.textContent = 'Sending...';

        var fd = new FormData(form);

        fetch(form.action, { method: 'POST', body: fd, headers: { Accept: 'application/json' } })
          .then(function (r) {
            return r.json().then(function (data) { return { status: r.status, data: data }; });
          })
          .then(function (out) {
            if (out.status >= 200 && out.status < 300 && out.data && out.data.ok) {
              ok.hidden = false;
              form.reset();
            } else {
              throw new Error((out.data && out.data.error) || 'Request failed');
            }
          })
          .catch(function () {
            var link = err.querySelector('.contact-mailto');
            if (link) link.setAttribute('href', buildMailto());
            err.hidden = false;
          })
          .finally(function () {
            btn.disabled = false;
            btn.textContent = original;
          });
      });
    });
  })();
</script>

<style is:global>
  .contact {
    padding: 4rem 1.5rem;
    background: var(--bg);
  }

  @media (min-width: 768px) {
    .contact {
      padding: 5rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .contact {
      padding: 5rem 3rem;
    }
  }

  .contact-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .contact h2 {
    margin: 0 0 0.75rem;
  }

  .contact-lead {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .contact-form {
    display: block;
  }

  .contact-field {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.25rem;
  }

  .contact-field label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .contact-required {
    color: var(--accent);
    margin-left: 0.15em;
  }

  .contact-field input,
  .contact-field textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--text);
    background: #FFFFFF;
    border: 1px solid #E8E0D5;
    border-radius: 4px;
    padding: 0.875rem;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .contact-field textarea {
    resize: vertical;
    min-height: 110px;
    line-height: 1.6;
  }

  .contact-field input:focus,
  .contact-field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }

  .contact-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .contact-submit {
    width: 100%;
    padding: 1rem 1.75rem;
    margin-top: 0.5rem;
  }

  .contact-submit[disabled] {
    opacity: 0.7;
    cursor: progress;
  }

  .contact-note {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 1rem 0 0;
    line-height: 1.5;
  }

  .contact-status {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 1rem 0 0;
    padding: 0.875rem 1rem;
    border-radius: 6px;
  }

  .contact-status--success {
    background: rgba(76, 132, 84, 0.1);
    border: 1px solid rgba(76, 132, 84, 0.3);
    color: #2F5A36;
  }

  .contact-status--error {
    background: var(--accent-soft);
    border: 1px solid rgba(139, 35, 49, 0.3);
    color: var(--accent);
  }

  .contact-mailto {
    color: var(--accent);
    font-weight: 500;
  }
</style>
